{
  "name": "help-and-support-employee-management",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3003",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3003",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:logs": "docker compose logs -f web",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build -d web",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "deploy:prod:win": "powershell -ExecutionPolicy Bypass -File scripts/deploy-production.ps1",
    "verify:prod": "bash scripts/verify-production.sh",
    "generate:faq-pdf": "node scripts/generate-faq-pdf.mjs",
    "db:clear-workforce": "node scripts/clear-workforce-support-data.mjs"
  },
  "dependencies": {
    "@twilio/voice-sdk": "^2.12.1",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.38.0",
    "jose": "^5.9.6",
    "mongoose": "^8.8.3",
    "next": "^14.2.15",
    "nodemailer": "^6.10.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "twilio": "^5.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.2"
  }
}
