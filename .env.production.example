# ============================================
# Help & Support — PRODUCTION (SaarthiWorkforce)
# ============================================
# Copy to .env on the production server (never commit real secrets):
#   cp .env.production.example .env
# Then fill every blank value and run:
#   ./scripts/deploy-production.sh
# ============================================

NODE_ENV=production

# Database — must reach your production Mongo (Docker service name or host)
# Example (same network as somethingx stack):
MONGODB_URI=mongodb://somethingx-mongodb:27017/saarthi_workforce_support
SUPPORT_MONGODB_DATABASE=

# JWT — MUST match Employeemanage / TalentX production secrets
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ORG_AUTH_JWT_SECRET=

# Admin / agents
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=admin@yourdomain.com
HELP_AGENT_PASSWORD=CHANGE_ME

# OpenAI
OPENAI_API_KEY=

# Email — Brevo
MAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_SMTP_LOGIN=Saarthiworkforce@gmail.com
BREVO_SMTP_USER=Saarthiworkforce@gmail.com
BREVO_SMTP_KEY=
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=Saarthiworkforce@gmail.com
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=Saarthiworkforce@gmail.com
SUPPORT_EMAIL_TO=Saarthiworkforce@gmail.com
SUPPORT_IMAP_USERNAME=Saarthiworkforce@gmail.com
SUPPORT_IMAP_PASSWORD=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=

# Public URLs — use your real production domain (no trailing slash)
# Example if Help & Support is reverse-proxied at https://help.yourdomain.com
APP_FRONTEND_URL=https://help.yourdomain.com
APP_CORS_ALLOWED_ORIGINS=https://help.yourdomain.com,https://yourdomain.com,https://www.yourdomain.com
SUPPORT_WEBHOOK_BASE_URL=https://help.yourdomain.com

# Client-visible (baked into the Docker image at build time)
NEXT_PUBLIC_WORKFORCE_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SAARTHIX_URL=https://saarthix.com
NEXT_PUBLIC_SUPPORT_EMAIL=Saarthiworkforce@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE_DISPLAY=+1 878 732 2485
NEXT_PUBLIC_SUPPORT_PHONE_E164=+18787322485
NEXT_PUBLIC_HELP_SUPPORT_URL=https://help.yourdomain.com
SUPPORT_COMPANY_NAME=SaarthiWorkforce
SUPPORT_PHONE_DISPLAY=+1 878 732 2485
SUPPORT_PHONE_E164=+18787322485

# Optional: host port mapping (default 3003)
# HELP_SUPPORT_HOST_PORT=3003
