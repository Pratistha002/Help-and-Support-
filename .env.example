# ============================================
# Help & Support — SaarthiWorkforce (SXworkforce)
# ============================================
# Independent from SaarthiX Help & Support. Copy to .env — DO NOT COMMIT .env
# ============================================

# Database — dedicated workforce support DB (do NOT use saarthix_support)
MONGODB_URI=mongodb://localhost:27017/saarthi_workforce_support
# Leave empty when the database name is already in MONGODB_URI
SUPPORT_MONGODB_DATABASE=
# JWT — must match Employeemanage / TalentX (Blueprint apps/api ORG_AUTH_JWT_SECRET or JWT_SECRET)
JWT_SECRET=change-this-in-production
ORG_AUTH_JWT_SECRET=

# Admin
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=Admin@221105
ADMIN_EMAIL=admin@saarthix.com
# Shared password for Help Admin agent login (name + email + this password)
HELP_AGENT_PASSWORD=Help@221716

# OpenAI (AI chat assistant)
OPENAI_API_KEY=

# ============================================
# EMAIL — Brevo API (preferred) + SMTP fallback
# ============================================
# 1. Sign up: https://www.brevo.com
# 2. Brevo → Settings → SMTP & API → API Keys → create key (xkeysib-...)
# 3. Brevo → Settings → SMTP & API → SMTP → Create SMTP key (xsmtpsib-...) optional fallback
# 4. APP_MAIL_FROM = verified sender in Brevo (Senders & IP)
#
MAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_SMTP_LOGIN=Saarthiworkforce@gmail.com
BREVO_SMTP_USER=Saarthiworkforce@gmail.com
BREVO_SMTP_KEY=
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=Saarthiworkforce@gmail.com
# Use BREVO_SMTP_KEY value here (xsmtpsib-...), not the Gmail account password
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=Saarthiworkforce@gmail.com
SUPPORT_EMAIL_TO=Saarthiworkforce@gmail.com
# If Brevo returns "unrecognised IP", add your public IP here:
# https://app.brevo.com/security/authorised_ips
# Optional Gmail app password — SMTP fallback when Brevo IP blocking is on
SUPPORT_IMAP_USERNAME=Saarthiworkforce@gmail.com
SUPPORT_IMAP_PASSWORD=

# Twilio — SMS & voice callbacks (required for SMS + call features)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
# Public URL Twilio can reach for status webhooks (no trailing slash)
SUPPORT_WEBHOOK_BASE_URL=
SUPPORT_PHONE_DISPLAY=+1 878 732 2485
SUPPORT_PHONE_E164=+18787322485

# Production hosted URL
APP_FRONTEND_URL=https://saarthix.com
APP_CORS_ALLOWED_ORIGINS=https://saarthix.com,http://localhost:3003,http://localhost:3002

# Saarthi Workforce (Employeemanage) — navbar logo, dashboard, profile, login links
NEXT_PUBLIC_WORKFORCE_APP_URL=http://localhost:3002

NEXT_PUBLIC_SUPPORT_EMAIL=Saarthiworkforce@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE_DISPLAY=+1 878 732 2485
NEXT_PUBLIC_SUPPORT_PHONE_E164=+18787322485
SUPPORT_COMPANY_NAME=SaarthiWorkforce
